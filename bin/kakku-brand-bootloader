#!/usr/bin/env bash
set -euo pipefail

limine_config_found=0

require_root() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    echo "Run as root: sudo kakku-brand-bootloader" >&2
    exit 1
  fi
}

backup_file() {
  local file="$1"
  if [[ -f "$file" && ! -f "$file.kakku.bak" ]]; then
    cp "$file" "$file.kakku.bak"
    echo "Backed up $file to $file.kakku.bak"
  fi
}

replace_os_name() {
  local file="$1"
  [[ -f "$file" ]] || return 0

  backup_file "$file"

  # Restore from backup first if we messed up kernel paths previously
  if grep -q "kernel_path.*kakkuos" "$file" && [[ -f "$file.kakku.bak" ]]; then
    cp "$file.kakku.bak" "$file"
  fi

  # Safely replace user-facing menu titles only. Limine top-level OS entries
  # start with a single "/" (for example "/+CachyOS"). Child kernel entries
  # start with "//" and are intentionally left alone.
  sed -i -E '/^[[:space:]]*\/[^/]/ s/[Cc]achy[Oo][Ss]/KakkuOS/g' "$file"
  sed -i -E '/^[[:space:]]*\/[^/]/ s/linux-cachyos/KakkuOS/g' "$file"
  sed -i -E '/^[[:space:]]*\/[^/]/ s/\(KakkuOS\)//g' "$file"
  sed -i -E '/^[[:space:]]*\/[^/]/ s/ - KakkuOS//g' "$file"

  sed -i -E '/^:/ s/[Cc]achy[Oo][Ss]/KakkuOS/g' "$file"
  sed -i -E '/^:/ s/linux-cachyos/KakkuOS/g' "$file"
  sed -i -E '/^:/ s/\(KakkuOS\)//g' "$file"
  sed -i -E '/^:/ s/ - KakkuOS//g' "$file"

  sed -i -E '/^title/ s/[Cc]achy[Oo][Ss]/KakkuOS/g' "$file"
  sed -i -E '/^title/ s/linux-cachyos/KakkuOS/g' "$file"

  sed -i -E '/^GRUB_DISTRIBUTOR/ s/[Cc]achy[Oo][Ss]/KakkuOS/g' "$file"

  # Clean up any weird dangling characters in menus
  sed -i -E '/^[[:space:]]*\/[^/]/ s/ - $//g' "$file"
  sed -i -E '/^[[:space:]]*\/[^/]/ s/ -$//g' "$file"
  sed -i -E '/^:/ s/ - $//g' "$file"
  sed -i -E '/^:/ s/ -$//g' "$file"

  echo "Safely branded bootloader menus in $file."
}

set_limine_target_os_name() {
  local file="/etc/default/limine"
  local tmp

  mkdir -p /etc/default
  touch "$file"
  backup_file "$file"
  tmp="$(mktemp)"

  if grep -Eq '^[[:space:]]*#?[[:space:]]*TARGET_OS_NAME=' "$file"; then
    sed -E 's/^[[:space:]]*#?[[:space:]]*TARGET_OS_NAME=.*/TARGET_OS_NAME="KakkuOS"/' "$file" > "$tmp"
  else
    cp "$file" "$tmp"
    printf '\nTARGET_OS_NAME="KakkuOS"\n' >> "$tmp"
  fi

  if ! cmp -s "$file" "$tmp"; then
    cp "$tmp" "$file"
    echo "Set Limine TARGET_OS_NAME=KakkuOS in $file."
  else
    echo "Limine TARGET_OS_NAME already set in $file."
  fi

  rm -f "$tmp"
}

brand_limine_config() {
  local file="$1"

  if [[ -f "$file" ]]; then
    limine_config_found=1
    replace_os_name "$file"
  fi
}

require_root

# For Limine
brand_limine_config /limine.conf
brand_limine_config /limine/limine.conf
brand_limine_config /boot/limine.conf
brand_limine_config /boot/limine/limine.conf
brand_limine_config /boot/efi/EFI/limine/limine.conf
brand_limine_config /boot/efi/EFI/Limine/limine.conf
brand_limine_config /boot/EFI/limine/limine.conf
brand_limine_config /boot/EFI/Limine/limine.conf
if [[ -d /etc/limine ]]; then
  for entry in /etc/limine/*.conf; do
    brand_limine_config "$entry"
  done
fi
if (( limine_config_found )) || [[ -f /etc/default/limine ]]; then
  set_limine_target_os_name
fi

# For systemd-boot
if [[ -d /boot/loader/entries ]]; then
  for entry in /boot/loader/entries/*.conf; do
    replace_os_name "$entry"
  done
fi

# For GRUB 
replace_os_name /etc/default/grub
if command -v grub-mkconfig >/dev/null 2>&1 && [[ -f /etc/default/grub ]]; then
  echo "If applying for GRUB, regenerate the config: sudo grub-mkconfig -o /boot/grub/grub.cfg"
fi

# Override CachyOS's limine auto-generator string if it exists
if [[ -f /etc/os-release ]]; then
  sed -i -E 's/PRETTY_NAME="[^"]*"/PRETTY_NAME="KakkuOS"/' /etc/os-release || true
fi

echo "Bootloader branding step complete."
