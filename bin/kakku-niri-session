#!/bin/sh

# Kakku-owned niri session launcher. This tracks the packaged niri-session
# flow, but imports explicit environment variable names for newer systemd.

valid_environment_names() {
  env | sed -n 's/^\([A-Za-z_][A-Za-z0-9_]*\)=.*/\1/p'
}

import_systemd_user_environment() {
  environment_names="$(valid_environment_names)"

  if [ -n "$environment_names" ]; then
    # Deliberately unquoted: environment_names only contains validated variable
    # names, and systemctl expects each name as a separate argument.
    systemctl --user import-environment $environment_names
  fi
}

update_dbus_activation_environment() {
  if hash dbus-update-activation-environment 2>/dev/null; then
    dbus-update-activation-environment --all
  fi
}

# Detect if being run as a user service, which implies external session
# management, and exec the compositor directly.
if [ -n "${MANAGERPID:-}" ] && [ "${SYSTEMD_EXEC_PID:-}" = "$$" ]; then
  case "$(ps -p "$MANAGERPID" -o cmd=)" in
    *systemd*--user*)
      exec niri --session
      ;;
  esac
fi

if [ -n "$SHELL" ] &&
  grep -q "$SHELL" /etc/shells &&
  ! (echo "$SHELL" | grep -q "false") &&
  ! (echo "$SHELL" | grep -q "nologin"); then
  if [ "$1" != '-l' ]; then
    exec bash -c "exec -l '$SHELL' -c '$0 -l $*'"
  else
    shift
  fi
fi

if hash systemctl >/dev/null 2>&1; then
  if systemctl --user -q is-active niri.service; then
    echo 'A niri session is already running.'
    exit 1
  fi

  systemctl --user reset-failed
  import_systemd_user_environment
  update_dbus_activation_environment

  systemctl --user --wait start niri.service
  systemctl --user start --job-mode=replace-irreversibly niri-shutdown.target
  systemctl --user unset-environment WAYLAND_DISPLAY DISPLAY XDG_SESSION_TYPE XDG_CURRENT_DESKTOP NIRI_SOCKET
elif hash dinitctl >/dev/null 2>&1; then
  if ! pgrep -u "$(id -u)" dinit >/dev/null 2>&1; then
    echo "dinit user daemon is not running."
    exit 1
  fi

  if dinitctl --quiet --user is-started niri 2>/dev/null; then
    echo 'A niri session is already running.'
    exit 1
  fi

  valid_environment_names | xargs dinitctl --quiet --user setenv 2>/dev/null
  update_dbus_activation_environment >/dev/null 2>&1

  mkdir --parents "$HOME/.local/share/niri"
  dinitctl --quiet --user start niri.target 2>&1
  dinit-monitor --user --initial -c $'sh -c " 
        if [ "%s" = "stopped" ] || [ "%s" = "failed" ]; then
            ppid=$(ps -o ppid= -p $$)
            kill $ppid
        fi"' niri >/dev/null 2>&1

  dinitctl --quiet --user unsetenv WAYLAND_DISPLAY DISPLAY XDG_SESSION_TYPE XDG_CURRENT_DESKTOP NIRI_SOCKET 2>/dev/null
else
  echo "No systemd or dinit detected, please use niri --session instead."
fi
