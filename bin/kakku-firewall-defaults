#!/usr/bin/env bash
set -euo pipefail

require_root() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    echo "Run as root: sudo kakku-firewall-defaults" >&2
    exit 1
  fi
}

require_root

if ! command -v ufw >/dev/null 2>&1; then
  echo "ufw not found; skipped firewall defaults." >&2
  exit 0
fi

ufw default deny incoming
ufw default allow outgoing
ufw --force enable
