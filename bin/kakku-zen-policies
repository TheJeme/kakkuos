#!/usr/bin/env bash
set -euo pipefail

source_file="${KAKKU_ZEN_POLICIES_SOURCE:-/usr/share/kakku/zen/policies.json}"
installed=0

install_policy() {
  local distribution_dir="$1"
  local target="$distribution_dir/policies.json"

  if [[ ! -d "$distribution_dir" && ! -d "$(dirname "$distribution_dir")" ]]; then
    return
  fi

  if (( EUID == 0 )); then
    install -Dm644 "$source_file" "$target"
  else
    sudo install -Dm644 "$source_file" "$target"
  fi

  echo "Installed: $target"
  installed=1
}

if [[ ! -f "$source_file" ]]; then
  echo "Missing Zen Browser policy source: $source_file" >&2
  exit 0
fi

install_policy /opt/zen-browser-bin/distribution
install_policy /usr/lib/zen-browser/distribution
install_policy /usr/lib/zen-browser-bin/distribution

if (( installed == 0 )); then
  echo "Zen Browser policy target not found; skipping extension policy install." >&2
fi
