pkgname=kakku-niri-settings
pkgver=0.1.0
pkgrel=1
pkgdesc="KakkuOS niri and DankMaterialShell desktop defaults"
arch=('any')
url="https://kakkuos.jeme.app/"
license=('MIT')
install=kakku-niri-settings.install
depends=(
  'niri'
  'xwayland-satellite'
  'xdg-desktop-portal-gnome'
  'xdg-desktop-portal-gtk'
  'dms-shell-niri'
  'matugen'
  'qt6-multimedia'
  'qt6-multimedia-ffmpeg'
  'wtype'
  'power-profiles-daemon'
  'i2c-tools'
  'curl'
  'wl-clipboard'
  'libqalculate'
  'ghostty'
  'fastfetch'
  'playerctl'
  'fontconfig'
  'ttf-jetbrains-mono-nerd'
  'zsh'
  'starship'
  'greetd'
  'greetd-tuigreet'
)
source=()
sha256sums=()

package() {
  local repo_root="$startdir/../.."

  install -dm755 "$pkgdir/etc/skel/.config"
  cp -r "$repo_root/dotfiles/niri" "$pkgdir/etc/skel/.config/niri"
  cp -r "$repo_root/dotfiles/fastfetch" "$pkgdir/etc/skel/.config/fastfetch"
  cp -r "$repo_root/dotfiles/lazygit" "$pkgdir/etc/skel/.config/lazygit"
  cp -r "$repo_root/dotfiles/yazi" "$pkgdir/etc/skel/.config/yazi"
  cp -r "$repo_root/dotfiles/btop" "$pkgdir/etc/skel/.config/btop"

  install -Dm644 "$repo_root/dotfiles/zsh/.zshrc" "$pkgdir/etc/skel/.zshrc"

  install -dm755 "$pkgdir/usr/share/backgrounds/kakku"
  cp -r "$repo_root/branding/." "$pkgdir/usr/share/backgrounds/kakku/"

  install -dm755 "$pkgdir/usr/share/kakku/packages"
  cp -r "$repo_root/packages/." "$pkgdir/usr/share/kakku/packages/"

  install -dm755 "$pkgdir/usr/share/kakku/zen"
  cp -r "$repo_root/system/zen/." "$pkgdir/usr/share/kakku/zen/"

  install -dm755 "$pkgdir/usr/bin"
  install -m755 "$repo_root"/bin/kakku* "$pkgdir/usr/bin/"

  install -Dm644 "$repo_root/system/pacman.d/hooks/kakku-zen-policies.hook" "$pkgdir/usr/share/libalpm/hooks/kakku-zen-policies.hook"

  install -Dm644 "$repo_root/system/environment.d/kakku.conf" "$pkgdir/etc/environment.d/kakku.conf"

  install -Dm644 "$repo_root/system/greetd/config.toml" "$pkgdir/etc/greetd/config.toml"

  install -dm755 "$pkgdir/usr/share/kakku"
  install -Dm644 "$repo_root/system/os-release" "$pkgdir/usr/share/kakku/os-release"
  install -Dm644 "$repo_root/README.md" "$pkgdir/usr/share/kakku/README.md"
}
